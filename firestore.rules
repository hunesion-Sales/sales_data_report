rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper Functions
    // ========================================

    // 인증된 사용자인지 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 사용자 문서 가져오기
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 관리자 권한 확인
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    // 특정 부문에 속한 사용자인지 확인
    function belongsToDivision(divisionId) {
      return isAuthenticated() && getUserData().divisionId == divisionId;
    }

    // ========================================
    // Users Collection
    // ========================================
    match /users/{userId} {
      // 읽기: 인증된 사용자는 모두 읽기 가능 (부문 목록 조회 등)
      allow read: if isAuthenticated();

      // 생성: 인증된 사용자 (회원가입 시)
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // 수정/삭제: 본인 또는 관리자만
      allow update, delete: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
    }

    // ========================================
    // Divisions Collection (영업부문)
    // ========================================
    match /divisions/{divisionId} {
      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // Products Master Collection (제품 마스터)
    // ========================================
    match /products/{productId} {
      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // Reports Collection (연간 보고서)
    // ========================================
    match /reports/{reportId} {
      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();

      // ----------------------------------------
      // Report Sub-collections
      // ----------------------------------------

      // Products (제품별 매출 데이터)
      match /products/{productDocId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
      }

      // Division Data (부문별 데이터)
      match /division_data/{divisionDataId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
      }

      // Upload History (업로드 이력)
      match /upload_history/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin();
        allow update, delete: if false; // 이력은 수정/삭제 불가
      }
    }

    // ========================================
    // Targets Collection (분기별 목표)
    // ========================================
    match /targets/{targetId} {
      // 읽기: 인증된 모든 사용자
      // (일반 사용자는 자신의 부문만 필터링하여 표시하는 것은 앱에서 처리)
      allow read: if isAuthenticated();

      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // Catch-all: 기본 거부
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
