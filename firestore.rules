rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper Functions
    // ========================================

    // 인증된 사용자인지 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 사용자 문서가 존재하는지 확인
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 사용자 문서 가져오기 (존재할 때만 호출해야 함)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 관리자 권한 확인 (문서 존재 여부 먼저 체크)
    function isAdmin() {
      return isAuthenticated() && userExists() && getUserData().role == 'admin';
    }

    // 승인된 사용자인지 확인
    function isApproved() {
      return isAuthenticated() && userExists() && getUserData().status == 'approved';
    }

    // 특정 부문에 속한 사용자인지 확인
    function belongsToDivision(divisionId) {
      return isAuthenticated() && userExists() && getUserData().divisionId == divisionId;
    }

    // ========================================
    // Field Validation Helpers
    // ========================================

    // 문자열 필드 검증
    function isNonEmptyString(val) {
      return val is string && val.size() > 0;
    }

    function isStringMaxLen(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // 숫자 필드 검증 (0 이상)
    function isNonNegativeNumber(val) {
      return val is number && val >= 0;
    }

    // 타임스탬프 필드 검증
    function isValidTimestamp(val) {
      return val is timestamp;
    }

    // ========================================
    // Users Collection
    // ========================================
    match /users/{userId} {

      // 사용자 생성 시 필드 검증
      function isValidUserCreate() {
        let data = request.resource.data;
        return data.keys().hasAll(['email', 'displayName', 'role', 'status', 'uid'])
          && isNonEmptyString(data.email)
          && isStringMaxLen(data.email, 254)
          && isNonEmptyString(data.displayName)
          && isStringMaxLen(data.displayName, 50)
          && data.role in ['admin', 'user']
          && data.status in ['pending', 'approved', 'rejected']
          && data.uid == userId;
      }

      // 사용자 수정 시 필드 검증
      function isValidUserUpdate() {
        let data = request.resource.data;
        return (!('email' in data) || (isNonEmptyString(data.email) && isStringMaxLen(data.email, 254)))
          && (!('displayName' in data) || (isNonEmptyString(data.displayName) && isStringMaxLen(data.displayName, 50)))
          && (!('role' in data) || data.role in ['admin', 'user'])
          && (!('status' in data) || data.status in ['pending', 'approved', 'rejected']);
      }

      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 생성: 인증된 사용자가 본인 uid로만 생성 가능 + 필드 검증
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && isValidUserCreate();

      // 수정: 본인 또는 관리자 + 필드 검증
      allow update: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin())
        && isValidUserUpdate();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================
    // Divisions Collection (영업부문)
    // ========================================
    match /divisions/{divisionId} {

      function isValidDivision() {
        let data = request.resource.data;
        return data.keys().hasAll(['name', 'sortOrder'])
          && isNonEmptyString(data.name)
          && isStringMaxLen(data.name, 100)
          && data.sortOrder is number;
      }

      // 읽기: 모든 사용자 (회원가입 시 목록 조회 필요)
      allow read: if true;

      // 생성/수정: 관리자만 + 필드 검증
      allow create, update: if isAdmin() && isValidDivision();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================
    // Products Master Collection (제품 마스터)
    // ========================================
    match /products_master/{productId} {

      function isValidProductMaster() {
        let data = request.resource.data;
        return data.keys().hasAll(['name', 'sortOrder'])
          && isNonEmptyString(data.name)
          && isStringMaxLen(data.name, 200)
          && data.sortOrder is number;
      }

      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정: 관리자만 + 필드 검증
      allow create, update: if isAdmin() && isValidProductMaster();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // 기존 products 컬렉션 (하위 호환)
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // Reports Collection (연간 보고서)
    // ========================================
    match /reports/{reportId} {

      function isValidReport() {
        let data = request.resource.data;
        return data.keys().hasAll(['year'])
          && data.year is number
          && data.year >= 2020
          && data.year <= 2100;
      }

      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정: 관리자 또는 승인된 사용자 + 필드 검증
      allow create, update: if (isAdmin() || isApproved()) && isValidReport();

      // 삭제: 관리자만
      allow delete: if isAdmin();

      // ----------------------------------------
      // Report Sub-collections
      // ----------------------------------------

      // Products (제품별 매출 데이터)
      match /products/{productDocId} {

        function isValidReportProduct() {
          let data = request.resource.data;
          return data.keys().hasAll(['product', 'months', 'sortOrder'])
            && isNonEmptyString(data.product)
            && isStringMaxLen(data.product, 200)
            && data.months is map
            && data.sortOrder is number;
        }

        allow read: if isAuthenticated();
        allow create, update: if (isAdmin() || isApproved()) && isValidReportProduct();
        allow delete: if isAdmin() || isApproved();
      }

      // Division Data (부문별 데이터)
      match /division_data/{divisionDataId} {

        function isValidDivisionData() {
          let data = request.resource.data;
          return data.keys().hasAll(['divisionName', 'months'])
            && isNonEmptyString(data.divisionName)
            && isStringMaxLen(data.divisionName, 100)
            && data.months is map;
        }

        allow read: if isAuthenticated();
        allow create, update: if (isAdmin() || isApproved()) && isValidDivisionData();
        allow delete: if isAdmin() || isApproved();
      }

      // Industry Group Data (산업군별 실적 데이터)
      match /industry_group_data/{igDocId} {

        function isValidIndustryGroupData() {
          let data = request.resource.data;
          return data.keys().hasAll(['industryGroupName', 'months'])
            && isNonEmptyString(data.industryGroupName)
            && isStringMaxLen(data.industryGroupName, 100)
            && data.months is map;
        }

        allow read: if isAuthenticated();
        allow create, update: if (isAdmin() || isApproved()) && isValidIndustryGroupData();
        allow delete: if isAdmin() || isApproved();
      }

      // Snapshots (주차별 스냅샷)
      match /snapshots/{snapshotId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin() || isApproved();

        match /products/{productId} {
          allow read: if isAuthenticated();
          allow create, update, delete: if isAdmin() || isApproved();
        }
      }
    }

    // ========================================
    // Targets Collection (분기별 목표)
    // ========================================
    match /targets/{targetId} {

      function isValidTarget() {
        let data = request.resource.data;
        return data.keys().hasAll(['year', 'quarter', 'divisionId', 'salesTarget'])
          && data.year is number
          && data.year >= 2020
          && data.year <= 2100
          && data.quarter in ['Q1', 'Q2', 'Q3', 'Q4']
          && isNonEmptyString(data.divisionId)
          && isNonNegativeNumber(data.salesTarget);
      }

      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정: 관리자만 + 필드 검증
      allow create, update: if isAdmin() && isValidTarget();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================
    // Industry Groups Collection (산업군)
    // ========================================
    match /industry_groups/{groupId} {

      function isValidIndustryGroup() {
        let data = request.resource.data;
        return data.keys().hasAll(['name', 'sortOrder'])
          && isNonEmptyString(data.name)
          && isStringMaxLen(data.name, 100)
          && data.sortOrder is number;
      }

      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정: 관리자만 + 필드 검증
      allow create, update: if isAdmin() && isValidIndustryGroup();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================
    // Product Group Targets Collection (제품군별 목표)
    // ========================================
    match /product_group_targets/{targetId} {

      function isValidProductGroupTarget() {
        let data = request.resource.data;
        return data.keys().hasAll(['year', 'quarter', 'productGroup', 'salesTarget'])
          && data.year is number
          && data.year >= 2020
          && data.year <= 2100
          && data.quarter in ['Q1', 'Q2', 'Q3', 'Q4']
          && isNonEmptyString(data.productGroup)
          && isStringMaxLen(data.productGroup, 100)
          && isNonNegativeNumber(data.salesTarget);
      }

      // 읽기: 인증된 모든 사용자
      allow read: if isAuthenticated();

      // 생성/수정: 관리자만 + 필드 검증
      allow create, update: if isAdmin() && isValidProductGroupTarget();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================
    // Backlog Collection (수주잔액)
    // ========================================
    match /backlog/{year} {

      // 메타 문서 읽기/쓰기
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isApproved();
      allow delete: if isAdmin();

      // 제품별 수주잔액
      match /products/{docId} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin() || isApproved();
        allow delete: if isAdmin() || isApproved();
      }

      // 부문별 수주잔액
      match /divisions/{docId} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin() || isApproved();
        allow delete: if isAdmin() || isApproved();
      }

      // 산업군별 수주잔액
      match /industry_groups/{docId} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin() || isApproved();
        allow delete: if isAdmin() || isApproved();
      }
    }

    // ========================================
    // Upload History Collection (Global)
    // ========================================
    match /uploadHistory/{historyId} {

      function isValidUploadHistory() {
        let data = request.resource.data;
        return data.keys().hasAll(['reportId', 'fileName', 'uploadedAt'])
          && isNonEmptyString(data.reportId)
          && isNonEmptyString(data.fileName)
          && isStringMaxLen(data.fileName, 500);
      }

      allow read: if isAuthenticated();
      allow create: if (isAdmin() || isApproved()) && isValidUploadHistory();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================
    // Catch-all: 기본 거부
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
